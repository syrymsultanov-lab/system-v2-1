          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {model: $env.OPENAI_MODEL || 'gpt-4.1-mini', response_format:{type:'json_object'}, messages:[{role:'system', content:'Return only valid JSON.'},{role:'user', content:$json.prompt}] } }}"
      },
