    {
      "parameters": {
        "jsCode": "const lead = Array.isArray($json.body) ? $json.body[0] : $json.body?.[0];\nconst prompt = `Ты AI qualifier SYSTEM V2. Верни JSON с keys: score, temperature, next_action, summary. Lead: ${JSON.stringify(lead)}`;\nreturn [{ job_id: $('Split Jobs').item.json.id, lead_id: lead.id, partner_id: lead.partner_id, prompt }];"
      },
