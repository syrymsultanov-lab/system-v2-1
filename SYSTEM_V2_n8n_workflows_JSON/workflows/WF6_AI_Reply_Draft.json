              "value": "={{$env.SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "={{'Bearer ' + $env.SUPABASE_SERVICE_ROLE_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {partner_id:$json.partner_id, target_type:'inbound_message', target_id:$json.target_id, recommendation_type:'reply_draft', recommendation_payload:{draft:$json.draft}, confidence:0.7} }}"
      },
      "id": "ba55cdb4-7dc8-4fb8-94c2-1443f0889565",
