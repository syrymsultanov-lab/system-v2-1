      "typeVersion": 4.2,
      "position": [
        -260,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const m = Array.isArray($json.body)?$json.body[0]:$json.body?.[0]; return [{job_id:$('Split Jobs').item.json.id, partner_id:m.partner_id, target_id:m.id, prompt:`Draft a concise helpful reply in Russian. Incoming: ${m.body}`}] ;"
      },
      "id": "dc64bd4d-229c-4465-828f-ac46b4d5e571",
      "name": "Build Reply Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -40,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.OPENAI_BASE_URL || 'https://api.openai.com/v1/chat/completions'}}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{'Bearer ' + $env.OPENAI_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {model:$env.OPENAI_MODEL || 'gpt-4.1-mini', messages:[{role:'system', content:'Return reply text only.'},{role:'user', content:$json.prompt}] } }}"
      },
      "id": "1b3cdbdd-5b90-45c8-acc6-9ae1eebf9362",
      "name": "OpenAI Draft",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        180,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{job_id:$('Build Reply Prompt').item.json.job_id, partner_id:$('Build Reply Prompt').item.json.partner_id, target_id:$('Build Reply Prompt').item.json.target_id, draft:$json.body?.choices?.[0]?.message?.content || ''}];"
      },
      "id": "29e4e0d5-fa65-4206-9159-0e3ead582b62",
      "name": "Extract Reply",
