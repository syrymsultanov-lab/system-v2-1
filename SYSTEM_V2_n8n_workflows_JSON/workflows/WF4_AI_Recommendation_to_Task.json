        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "={{'Bearer ' + $env.SUPABASE_SERVICE_ROLE_KEY}}"
            }
          ]
        }
      },
      "id": "ff2a1763-07a6-4132-8cdc-be4cc3b04854",
      "name": "Fetch Recommendations",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -480,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "return (Array.isArray($json.body)?$json.body:[]).map(r => ({partner_id:r.partner_id, lead_id:r.target_id, title:`AI: ${r.recommendation_payload?.next_action || 'Follow up'}`, status:'todo'}));"
      },
      "id": "3c4271f3-a514-4d76-b7f4-71c131d2ab65",
      "name": "Map To Tasks",
